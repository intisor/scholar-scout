{
  "manifest_version": 3,
  "name": "ScholarScout",
  "version": "1.0.0",
  "description": "Intelligent scholarship pipeline: discover, track, and share vetted opportunities.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "contextMenus",
    "identity",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.notion.com/*",
    "https://www.notion.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://api.cerebras.ai/*",
    "https://api.mistral.ai/*",
    "https://openrouter.ai/*",
    "https://hermes.ai.unturf.com/*",
    "https://qwen.ai.unturf.com/*",
    "https://text.pollinations.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ScholarScout",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html?panel=1"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "MacCtrl+Shift+O"
      },
      "description": "Open ScholarScout quick save"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/scraper.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
